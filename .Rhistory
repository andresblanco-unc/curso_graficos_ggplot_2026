linetype = especie,
col = especie)) +
geom_point() +
geom_line()
# clasificación continua
ggplot(datos_peces,
aes(longitud_cm, peso_g,
fill = temperatura_C)) +
geom_point(alpha = .75, shape = 21, size = 7)
