scale_y_continuous(expand = c(0, 0), limits = c(0, 20),
breaks = seq(0, 20, by = 2.5)) +
scale_x_continuous(expand = c(0, 0),
breaks = seq(1960, 2025, by = 5)) +
labs(x = "Años",
y = "Superficie sembrada (millones de ha)") +
