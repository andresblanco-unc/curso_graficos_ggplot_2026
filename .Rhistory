THEME
# Combinando columnas y líneas
# Comparamos rendimiento global con Argentina
soja_arg_mundo %>%
mutate(Area = fct_recode(Area,
"Argentina" = "Argentina",
"Mundo"     = "World")) %>%
ggplot(aes(Year, Yield, fill = Area)) +
geom_col(position = "dodge") +
scale_y_continuous(expand = c(0, 0), breaks = seq(0, 5, by = .5)) +
scale_x_continuous(expand = c(0, 0), breaks = seq(1960, 2025, by = 5)) +
labs(x = "Años",
y = "Rendimiento (Tn/ha)") +
THEME +
theme(legend.position = c(.2, .85))
# Poco claro. Mejor columnas + línea superpuesta
ggplot(argentina, aes(Year, Yield)) +
geom_col(fill = "cornflowerblue") +
scale_y_continuous(expand = c(0, 0), breaks = seq(0, 5, by = .5),
labels = function(x) format(x, decimal.mark = ",",
scientific = FALSE)) +
scale_x_continuous(expand = c(0, 0), breaks = seq(1960, 2023, by = 5)) +
labs(x = "Años",
y = "Rendimiento [Tn/ha]") +
geom_line(data  = mundo, aes(Year, Yield), col = "red") +
geom_point(data = mundo, aes(Year, Yield), col = "red", size = 2) +
annotate("text", x = 1990, y = 2.5, label = "Argentina", col = "cornflowerblue", size = 6) +
annotate("text", x = 1965, y = 1.6, label = "Mundo",     col = "red",            size = 6) +
THEME
ggplot(argentina, aes(Year, Yield)) +
geom_col(fill = "darkolivegreen2") +
scale_y_continuous(expand = c(0, 0), limits = c(0, 3.5),
breaks = seq(0, 5, by = .5),
labels = function(x) format(x, decimal.mark = ",",
scientific = FALSE)) +
THEME
ggplot(argentina, aes(Year, Production)) +
geom_point(col = "blue3", size = 4) +
geom_line(col  = "blue3") +
scale_y_continuous(expand = c(0, 0), limits = c(0, 70),
breaks = seq(0, 75, by = 10)) +
THEME
# relacionamos los ejes
RELACION <- 70 / 3.5
ggplot(argentina, aes(x = Year)) +
geom_col(aes(y = Yield), fill = "darkolivegreen2") +
scale_y_continuous(expand = c(0, 0), limits = c(0, 3.5),
breaks = seq(0, 5, by = .5),
labels = function(x) format(x, decimal.mark = ",",
scientific = FALSE),
sec.axis = sec_axis(~ . * RELACION,
name   = "Producción (millones de Tn)",
breaks = seq(0, 70, by = 5))) +
scale_x_continuous(expand = c(0, 0), breaks = seq(1960, 2023, by = 5)) +
labs(x = "Años",
y = "Rendimiento (Tn/ha)") +
geom_line(aes(y  = Production / RELACION), col = "blue3") +
geom_point(aes(y = Production / RELACION), col = "blue3", size = 4) +
annotate("text", x = 1990, y = 2.5, label = "Rendimiento", col = "darkolivegreen4", size = 6) +
annotate("text", x = 2010, y = 1,   label = "Producción",  col = "blue3",           size = 6) +
THEME
# pivot_longer
soja %>%
pivot_longer(c(`Sup`, `Yield`, `Production`),
names_to  = "Variables",
values_to = "Valor")
# pivot_wider
soja %>%
select(Area, Year, Production) %>%
filter(Year == 1961 | Year == 2023) %>%
pivot_wider(names_from  = Year,
values_from = Production) %>%
mutate(Prop = `2023` / `1961`)
soja %>%
select(Area, Year, Sup, Production) %>%
filter(Area %in% c("Argentina", "World")) %>%
pivot_longer(c(`Sup`, `Production`),
names_to  = "variable",
values_to = "value") %>%
pivot_wider(names_from  = Area,
values_from = value) %>%
mutate(
prop = Argentina / World,
porc = prop * 100   # notar que podemos usar la variable recién creada
) %>%
ggplot(aes(Year, porc, col = variable)) +
geom_point() +
geom_line() +
scale_y_continuous(limits = c(0, 22), expand = c(0, 0),
breaks = seq(0, 25, by = 2)) +
scale_x_continuous(expand = c(0, 0), breaks = seq(1960, 2025, by = 5)) +
labs(x = "Años",
y = "Porcentaje del global") +
scale_colour_manual(values = c("Sup" = "blue4", "Production" = "red"),
guide  = "none") +
annotate("text", x = 2007, y = 10, label = "Superficie\ncultivada", col = "blue4", size = 5) +
annotate("text", x = 1995, y = 18, label = "Producción",            col = "red",   size = 5) +
THEME
soja_apilado_otros <- soja_paises %>%
filter(Year %in% años_seleccion) %>%
select(Area, Year, Production) %>%
pivot_wider(names_from = Area, values_from = Production) %>%
mutate(
Production = World - Brazil - USA - Argentina - China - India - Paraguay,
Area       = "Otros",
Sup        = NA,
Yield      = NA
) %>%
select(Year, Area, Production, Sup, Yield) %>%
bind_rows(
soja_paises %>%
filter(Year %in% años_seleccion, Area != "World")
) %>%
mutate(Area = factor(Area,
levels = c("Brazil", "USA", "Argentina",
"China", "India", "Paraguay", "Otros"))) %>%
group_by(Year) %>%
arrange(Year, Area) %>%
mutate(
percent_Prod = Production / sum(Production) * 100,
label_y      = cumsum(Production),
label_y_perc = cumsum(percent_Prod)
) %>%
ungroup()
G4 <- soja_apilado_otros %>%
ggplot(aes(x = factor(Year), y = Production, fill = Area)) +
geom_col() +
geom_text(aes(label = round(Production, 1), y = label_y),
vjust = 1.5, size = 3) +
labs(x = "Año", y = "Producción (millones de Tn)", fill = "País") +
THEME; G4
G5 <- soja_apilado_otros %>%
ggplot(aes(x = factor(Year), y = percent_Prod, fill = Area)) +
geom_col() +
geom_text(aes(label = round(percent_Prod, 1), y = label_y_perc),
vjust = 2, size = 3) +
labs(x = "Año", y = "Porcentaje de la producción mundial", fill = "País") +
THEME; G5
