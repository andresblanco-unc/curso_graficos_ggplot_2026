# eliminamos un dato influyente
fit_Jenysia_2 <-lm(peso_g ~ longitud_cm, data = JENYNSIA[-23,])
summary(fit_Jenysia_2)
# creamos una variable discreta para comparar
JENYNSIA$long_cat <- as.integer(round(JENYNSIA$longitud_cm, digits = 0))
JENYNSIA <- JENYNSIA %>%
mutate(long_cat2 = round(longitud_cm, digits = 0))
plot(JENYNSIA$long_cat, JENYNSIA$peso_g, pch=19)
fit_Jenysia_3 <-lm(peso_g ~ long_cat, data = JENYNSIA)
# Gráfico de Supuestos
layout(matrix(1:4, 2, 2)); plot(fit_Jenysia_3) ;layout(1)
shapiro.test(resid(fit_Jenysia_3))
bartlett.test(resid(fit_Jenysia_3)~JENYNSIA$long_cat)
boxplot(residuals(fit_Jenysia_3,type="pearson")~JENYNSIA$long_cat,
ylab="Pearson standarized residuals")
# Tablas
summary(fit_Jenysia_3)
## Gráficos de puntos -----------
### Plot -----
# el más rápido de Rbase
plot(peso_g~longitud_cm, data = JENYNSIA, pch=15)
plot(x = JENYNSIA$peso_g,
y = JENYNSIA$longitud_cm,  # explicito la y
col = "#8B2323",
pch=15)
### lineplot -----
# Con el paquete sciplot, rápido y efectivo
lineplot.CI(x.factor = longitud_cm,
response = peso_g,
data = JENYNSIA)
lineplot.CI(longitud_cm, peso_g, data = JENYNSIA)
# para eje x discreto
lineplot.CI(x.factor = long_cat,
response = peso_g,
data = JENYNSIA)
#para ver la ayuda de la función
?lineplot.CI
# Vemos un ejemplo más completo
lineplot.CI(x.factor = long_cat,
response = peso_g,
data = JENYNSIA, # dataset
group = temporada, # criterio de agrupamiento
col= c("darkorange","blue"), # color
las=1, # cambia la inclinación de los números de eje
ylim = c(0,5), # establece los límites del eje y
xlim = c(3.5,7),
x.cont = TRUE,
xlab="Longitud en peces",
ylab=" ",
cex.axis=1.2,
main= "Peso vs Longitud",
legend = T,
x.leg = 4,
leg.lab = c("Invierno", "Verano"),
err.width = .05,
lwd = 1.5)
# parámetros gráficos secundarios, nos sirven para agregar cosas a un gráfico
title(ylab= "Peso (g)", line = 2.5)
abline(h=1.5, col="red", lty=2)
abline(v=5, col="red", lty=2)
ggplot(data = JENYNSIA, # el data set
aes(x = longitud_cm, y = peso_g))
G1 <- ggplot(data = JENYNSIA, # el data set
aes(x = longitud_cm, y = peso_g)) + # x e y dentro de aes
geom_point() # indica que el gráfico es de puntos
G1
# se pueden agregar como capas nuevas diferentes geoms
G1 + geom_line(col="deeppink3")
# Podemos agregar la línea de regresión
G1 + geom_smooth(method = "lm",
col = "red",
fill="blue",
alpha=.2)
ggplot(data = JENYNSIA,
aes(longitud_cm, peso_g))+
geom_point(shape= 21,
size = 5,
col = "violetred4",
fill= "violetred2")
# veamos ahora si queremos clasificar por algún factor por color
G2 <- ggplot(JENYNSIA,
aes(longitud_cm, peso_g,
col = temporada)) + # agregamos en el aes por qué parámetro dividir
geom_point(size = 3)
G2
# ahora si queremos graficar la variable discreta, incluimos un stat_summary
# sin el stat
ggplot(JENYNSIA, aes(long_cat, peso_g)) +
geom_point()
# con el stat
ggplot(data = JENYNSIA,
aes(long_cat, peso_g))+
stat_summary(fun.data = mean_se,
geom="errorbar",
width = 0.1) +
stat_summary(fun = mean, geom="point",
size= 5, col ="violetred3")
# evaluaremos el efecto del sitio de muestreo sobre el cortisol plasmático
PEJERREY <- datos_peces %>% filter(especie == "Odontesthes bonariensis")
fit3 <- lm(cortisol_ugdL ~ sitio, data = PEJERREY)
# Gráfico de Supuestos
layout(matrix(1:4, 2, 2)); plot(fit3) ; layout(1)
shapiro.test(resid(fit3))
bartlett.test(resid(fit3) ~ PEJERREY$sitio)
boxplot(residuals(fit3, type = "pearson") ~ PEJERREY$sitio,
ylab = "Pearson standarized residuals")
# Probamos transformando por el logaritmo
fit3 <- lm(log(cortisol_ugdL) ~ sitio, data = PEJERREY)
layout(matrix(1:4, 2, 2)); plot(fit3) ; layout(1)
shapiro.test(resid(fit3))
bartlett.test(resid(fit3) ~ PEJERREY$sitio)
boxplot(residuals(fit3, type = "pearson") ~ PEJERREY$sitio,
ylab = "Pearson standarized residuals")
fit3 <- lm(cortisol_ugdL ~ sitio, data = PEJERREY)
# Tablas
anova(fit3)
summary(fit3)
# Tukey
library(agricolae)
tukey1 <- HSD.test(fit3, "sitio")
tukey1$groups
### ANOVA bifactorial con interacción -----
fit4 <- lm(cortisol_ugdL ~ sitio * sexo, data = PEJERREY)
# Gráfico de Supuestos
layout(matrix(1:4, 2, 2)); plot(fit4) ; layout(1)
shapiro.test(resid(fit4))
# la homogeneidad se prueba para cada factor
bartlett.test(resid(fit4) ~ PEJERREY$sitio)
bartlett.test(resid(fit4) ~ PEJERREY$sexo)
boxplot(residuals(fit4, type = "pearson") ~ PEJERREY$sitio,
ylab = "Pearson standarized residuals")
boxplot(residuals(fit4, type = "pearson") ~ PEJERREY$sexo,
ylab = "Pearson standarized residuals")
# Tablas
anova(fit4)
summary(fit4)
# Tukey
tukey1 <- HSD.test(fit4, "sitio")
tukey1$groups
tukey2 <- HSD.test(fit4, "sexo")
tukey2$groups
tukey3 <- HSD.test(fit4, c("sitio", "sexo"))
tukey3$groups
### sciplot -----
bargraph.CI(data = PEJERREY,
x.factor = sitio,
response = cortisol_ugdL)
bargraph.CI(data = PEJERREY,
x.factor = sitio,
response = cortisol_ugdL,
group = sexo)
bargraph.CI(data = PEJERREY,
x.factor = sitio,
response = cortisol_ugdL,
group = sexo,
ylim = c(0, 8),
legend = T,
col = c("honeydew",
"honeydew4"),
las = 1,
xlab = "Sitio de muestreo",
ylab = "Cortisol (µg/dL)",
cex.axis = 0.8,
lc = F); abline(h = 0)
### ggplot2 ----
# ggplot sin clasificación por color
PEJERREY %>%
ggplot(aes(x = sitio, y = cortisol_ugdL)) +
geom_col()
# transformación de los datos para calcular media y error estándar
PEJERREY %>% select(sitio, cortisol_ugdL) %>%
group_by(sitio) %>%
summarise_all(list(mean_se))
PEJERREY %>% select(sitio, cortisol_ugdL) %>%
group_by(sitio) %>%
summarise_all(list(media = mean,
error = se)) #sciplot
PEJERREY %>% select(sitio, cortisol_ugdL) %>%
group_by(sitio) %>%
summarise_all(list(cortisol_mean = mean,
cortisol_se = se))
PEJERREY %>% select(sitio, cortisol_ugdL) %>%
group_by(sitio) %>%
summarise_all(list(mean_se)) %>%
ggplot(aes(x = sitio, y = cortisol_ugdL$y)) +
geom_col()
PEJERREY %>% select(sitio, cortisol_ugdL) %>%
group_by(sitio) %>%
summarise_all(list(mean_se)) %>%
ggplot(aes(x = sitio, y = cortisol_ugdL$y)) +
geom_col() +
geom_errorbar(aes(ymin = cortisol_ugdL$ymin,
ymax = cortisol_ugdL$ymax),
width = .1)
# ggplot con clasificación por color
PEJERREY %>% select(sexo, sitio, cortisol_ugdL) %>%
group_by(sexo, sitio) %>%
summarise_all(list(mean_se))
PEJERREY %>% select(sexo, sitio, cortisol_ugdL) %>%
group_by(sexo, sitio) %>%
summarise_all(list(mean_se)) %>%
ggplot(aes(sitio, cortisol_ugdL$y, fill = sexo)) +
geom_col()
PEJERREY %>% select(sexo, sitio, cortisol_ugdL) %>%
group_by(sexo, sitio) %>%
summarise_all(list(mean_se)) %>%
ggplot(aes(sitio, cortisol_ugdL$y, fill = sexo)) +
geom_col(position = "dodge", # ajustamos el position
col = "black")
# editando el position y agregando barras de error
G3 <- PEJERREY %>% select(sexo, sitio, cortisol_ugdL) %>%
group_by(sexo, sitio) %>%
summarise_all(list(mean_se)) %>%
ggplot(aes(sitio, cortisol_ugdL$y, fill = sexo)) +
geom_col(position = "dodge") +
geom_errorbar(aes(ymin = cortisol_ugdL$ymin, ymax = cortisol_ugdL$ymax),
width = .1,
position = position_dodge(.9))
G3 +
ylim(0, 8)
# Podemos agregar las letras del Tukey
G3 <- G3 + geom_text(aes(y = cortisol_ugdL$ymax,
label = c("bc", "c", "b", "b", "bc", "a")),
position = position_dodge(0.9),
vjust = -.5); G3
# El mismo gráfico con stat_summary
ggplot(PEJERREY, aes(sitio, cortisol_ugdL, fill = sexo)) +
stat_summary(fun = mean, geom = "col",
position = position_dodge(0.9)) +
stat_summary(fun.data = mean_se, geom = "errorbar",
width = 0.1,
position = position_dodge(0.9))
# El mismo gráfico con stat_summary
ggplot(PEJERREY, aes(sitio, cortisol_ugdL, fill = sexo)) +
stat_summary(fun = mean, geom = "col",
position = position_dodge(0.9)) +
stat_summary(fun.data = mean_se, geom = "errorbar",
width = 0.1,
position = position_dodge(0.9)) +
theme_bw()
